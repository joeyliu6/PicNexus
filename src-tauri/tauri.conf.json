{
  "productName": "PicNexus",
  "version": "1.0.3",
  "identifier": "us.picnex.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: https://* http://*; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; connect-src 'self' https://* http://*; font-src 'self' data:",
      "dangerousDisableAssetCspModification": ["style-src"]
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "PicNexus",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "shadow": true,
        "visible": false,
        "label": "main",
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/qiyu-token-fetcher",
      "binaries/nami-token-fetcher"
    ],
    "resources": ["icons/icon.png"]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/joeyliu6/PicNexus/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzRDMyNTkyMTYxRjU3Q0MKUldUTVZ4OFdraVhUSXpwR1E4cW5xa0FSWllHMTB1Z0FCaHExTzNPamxJNjVTR0pacWZ4eVNYQ2YK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
