#!/usr/bin/env sh
# Local CI gate before pushing.
#
# This intentionally mirrors the failure-prone parts of GitHub Actions:
# typecheck, lint, build, coverage thresholds, and Rust tests.
# To bypass in an emergency: git push --no-verify

set -e

case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*) NPM=npm.cmd ;;
  *) NPM=npm ;;
esac

echo "[pre-push] Running frontend CI gate..."
"$NPM" run ci:prepush

echo "[pre-push] Running Rust tests..."
(cd src-tauri && cargo test --quiet)

echo "[pre-push] All checks passed. Pushing..."
