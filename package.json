{
  "name": "picnexus",
  "version": "1.0.5",
  "description": "PicNexus - 多图床上传工具",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:run": "npm run test:unit",
    "test:coverage": "vitest run --coverage && node scripts/check-critical-coverage.mjs",
    "test:visual": "playwright test -c playwright.config.ts",
    "test:visual:update": "playwright test -c playwright.config.ts --update-snapshots=all",
    "test:e2e": "playwright test -c playwright.e2e.config.ts",
    "test:tauri:e2e": "node scripts/check-tauri-e2e-prereqs.cjs && wdio run wdio.tauri.e2e.conf.cjs",
    "lint": "node scripts/check-logging-guards.mjs && eslint . && stylelint \"src/**/*.{css,vue}\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.{css,vue}\" --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@primevue/themes": "^4.5.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-log": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vueuse/core": "^14.0.0",
    "p-limit": "^7.2.0",
    "photoswipe": "^5.4.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.1",
    "vue": "^3.5.24"
  },
  "lint-staged": {
    "src/**/*.{ts,vue}": [
      "eslint --fix",
      "vitest related --run"
    ],
    "src/**/*.{css,vue}": [
      "stylelint --fix"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20.10.6",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "icon-gen": "^5.0.0",
    "lint-staged": "^16.4.0",
    "postcss-html": "^1.8.1",
    "sharp": "^0.34.5",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.2.7"
  }
}
