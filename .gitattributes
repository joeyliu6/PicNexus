# Auto detect text files and perform LF normalization
* text=auto

# Keep source and configuration files checked out with LF on every platform.
.gitattributes text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.husky/* text eol=lf
